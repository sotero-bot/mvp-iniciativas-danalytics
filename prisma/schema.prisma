generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model InstanciaActividad {
  id              String        @id
  actividadId     String
  usuarioId       String?
  accessToken     String        @unique
  estado          String
  activo          Boolean       @default(true)
  fechaInicio     DateTime?
  fechaFin        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  emailReferencia String?
  actividad       Actividad     @relation(fields: [actividadId], references: [id])
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id])
  interacciones   Interaccion[]
}

model Interaccion {
  id               String             @id @default(uuid())
  instanciaId      String
  pasoId           String
  contenido        String
  respuestaUsuario String?
  respuestaIa      String?
  archivoNombre    String?
  fecha            DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  instancia        InstanciaActividad @relation(fields: [instanciaId], references: [id])
  paso             PasoActividad      @relation(fields: [pasoId], references: [id])

  @@unique([instanciaId, pasoId])
  @@index([pasoId])
}

model Empresa {
  id                       String       @id @default(uuid())
  nombre                   String
  activo                   Boolean      @default(true)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  logoUrl                  String?
  contextoPdfNombre        String?
  contextoPdfTexto         String?      @db.Text
  contextoPdfActualizadoEn DateTime?
  iniciativas              Iniciativa[]
  usuarios                 Usuario[]
}

model Iniciativa {
  id          String      @id @default(uuid())
  nombre      String
  descripcion String?
  empresaId   String
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  actividades Actividad[]
  empresa     Empresa     @relation(fields: [empresaId], references: [id])
}

model PlantillaActividad {
  id          String          @id @default(uuid())
  nombre      String
  descripcion String?
  orden       Int?
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  pasos       PasoPlantilla[]
  actividades Actividad[]
}

model PasoPlantilla {
  id             String             @id @default(uuid())
  plantillaId    String
  titulo         String
  objetivo       String?
  instrucciones  String?
  usarIa         Boolean            @default(false)
  iaAutomatica   Boolean            @default(false)
  promptIa       String?
  permitirArchivo Boolean           @default(false)
  soloArchivo     Boolean           @default(false)
  urlPlantilla   String?
  orden          Int
  activo         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  plantilla      PlantillaActividad @relation(fields: [plantillaId], references: [id])

  @@unique([plantillaId, orden])
}

model Actividad {
  id                String               @id @default(uuid())
  nombre            String
  descripcion       String?
  estado            String               @default("inactiva")
  iniciativaId      String
  plantillaOrigenId String?
  activo            Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  iniciativa        Iniciativa           @relation(fields: [iniciativaId], references: [id])
  plantillaOrigen   PlantillaActividad?  @relation(fields: [plantillaOrigenId], references: [id])
  enlaces           EnlaceActividad[]
  instancias        InstanciaActividad[]
  pasos             PasoActividad[]
}

model EnlaceActividad {
  id          String    @id @default(uuid())
  actividadId String
  accessToken String    @unique
  nombre      String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  actividad   Actividad @relation(fields: [actividadId], references: [id])
}

model PasoActividad {
  id              String        @id @default(uuid())
  actividadId     String
  titulo          String
  objetivo        String?
  instrucciones   String?
  promptIa        String?
  usarIa          Boolean       @default(false)
  iaAutomatica    Boolean       @default(false)
  permitirArchivo Boolean       @default(false)
  soloArchivo     Boolean       @default(false)
  urlPlantilla    String?
  orden           Int
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  interacciones   Interaccion[]
  actividad       Actividad     @relation(fields: [actividadId], references: [id])

  @@unique([actividadId, orden])
  @@index([actividadId])
}

model Usuario {
  id         String               @id @default(uuid())
  nombre     String
  email      String
  cargo      String?
  empresaId  String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  estado     String               @default("activo")
  activo     Boolean              @default(true)
  area       String?
  instancias InstanciaActividad[]
  empresa    Empresa              @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, email], name: "empresa_email_unico")
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  nombre    String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activo    Boolean  @default(true)
}
