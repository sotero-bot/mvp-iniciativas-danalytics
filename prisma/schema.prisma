generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model InstanciaActividad {
  id              String         @id
  actividadId     String
  usuarioId       String?
  accessToken     String         @unique
  estado          String
  activo          Boolean        @default(true)
  fechaInicio     DateTime?
  fechaFin        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  emailReferencia String?
  actividad       Actividad      @relation(fields: [actividadId], references: [id])
  usuario         Usuario?       @relation(fields: [usuarioId], references: [id])
  interacciones   Interaccion[]
  respuestas      Respuesta[]
  canvasBloques   CanvasBloque[]
}

model Interaccion {
  id               String             @id @default(uuid())
  instanciaId      String
  pasoId           String
  contenido        String
  respuestaUsuario String?
  respuestaIa      String?
  archivoNombre    String?
  contenidoArchivo String?            @db.Text
  fecha            DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  instancia        InstanciaActividad @relation(fields: [instanciaId], references: [id])
  paso             PasoActividad      @relation(fields: [pasoId], references: [id])

  @@unique([instanciaId, pasoId])
  @@index([pasoId])
}

model Empresa {
  id                       String       @id @default(uuid())
  nombre                   String
  sector                   String?
  tipoOrganizacion         String?
  activo                   Boolean      @default(true)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  logoUrl                  String?
  contextoPdfNombre        String?
  contextoPdfTexto         String?      @db.Text
  contextoPdfActualizadoEn DateTime?
  dominioGoogleWorkspace   String?
  iniciativas              Iniciativa[]
  usuarios                 Usuario[]
  programas                Programa[]
  usuariosCliente          UsuarioCliente[]
}

model Role {
  id          String    @id @default(uuid())
  slug        String    @unique
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  usuarios    Usuario[]
}

model Iniciativa {
  id          String      @id @default(uuid())
  nombre      String
  descripcion String?
  empresaId   String
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  actividades Actividad[]
  empresa     Empresa     @relation(fields: [empresaId], references: [id])
}

model PlantillaActividad {
  id          String          @id @default(uuid())
  nombre      String
  descripcion String?
  orden       Int?
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  pasos       PasoPlantilla[]
  actividades Actividad[]
}

model PasoPlantilla {
  id              String              @id @default(uuid())
  plantillaId     String
  titulo          String
  objetivo        String?
  instrucciones   String?
  usarIa          Boolean             @default(false)
  iaAutomatica    Boolean             @default(false)
  promptIa        String?
  permitirArchivo Boolean             @default(false)
  soloArchivo     Boolean             @default(false)
  urlPlantilla    String?
  ejemploKey      String?
  orden           Int
  activo          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  plantilla       PlantillaActividad  @relation(fields: [plantillaId], references: [id])
  preguntas       PreguntaPlantilla[]

  @@unique([plantillaId, orden])
}

model PreguntaPlantilla {
  id                String        @id @default(uuid())
  pasoId            String
  orden             Int
  enunciado         String        @db.Text
  permitirArchivo   Boolean       @default(false)
  soloArchivo       Boolean       @default(false)
  subirArchivoS3    Boolean       @default(false)
  usarIa            Boolean       @default(false)
  iaAutomatica      Boolean       @default(false)
  promptIa          String?       @db.Text
  urlPlantilla      String?
  urlPromptTemplate String?
  activo            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paso              PasoPlantilla @relation(fields: [pasoId], references: [id])

  @@unique([pasoId, orden])
  @@index([pasoId])
}

model Actividad {
  id                String               @id @default(uuid())
  nombre            String
  descripcion       String?
  estado            String               @default("inactiva")
  iniciativaId      String
  plantillaOrigenId String?
  activo            Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  iniciativa        Iniciativa           @relation(fields: [iniciativaId], references: [id])
  plantillaOrigen   PlantillaActividad?  @relation(fields: [plantillaOrigenId], references: [id])
  enlaces           EnlaceActividad[]
  instancias        InstanciaActividad[]
  pasos             PasoActividad[]
}

model EnlaceActividad {
  id          String    @id @default(uuid())
  actividadId String
  accessToken String    @unique
  nombre      String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  actividad   Actividad @relation(fields: [actividadId], references: [id])
}

model PasoActividad {
  id              String              @id @default(uuid())
  actividadId     String
  titulo          String
  objetivo        String?
  instrucciones   String?
  promptIa        String?
  usarIa          Boolean             @default(false)
  iaAutomatica    Boolean             @default(false)
  permitirArchivo Boolean             @default(false)
  soloArchivo     Boolean             @default(false)
  urlPlantilla    String?
  ejemploKey      String?
  orden           Int
  activo          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  interacciones   Interaccion[]
  actividad       Actividad           @relation(fields: [actividadId], references: [id])
  preguntas       PreguntaActividad[]
  canvasBloques   CanvasBloque[]

  @@unique([actividadId, orden])
  @@index([actividadId])
}

model PreguntaActividad {
  id                String        @id @default(uuid())
  pasoId            String
  orden             Int
  enunciado         String        @db.Text
  permitirArchivo   Boolean       @default(false)
  soloArchivo       Boolean       @default(false)
  subirArchivoS3    Boolean       @default(false)
  usarIa            Boolean       @default(false)
  iaAutomatica      Boolean       @default(false)
  promptIa          String?       @db.Text
  urlPlantilla      String?
  urlPromptTemplate String?
  activo            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paso              PasoActividad @relation(fields: [pasoId], references: [id])
  respuestas        Respuesta[]

  @@unique([pasoId, orden])
  @@index([pasoId])
}

model Respuesta {
  id               String             @id @default(uuid())
  instanciaId      String
  preguntaId       String
  contenido        String?            @db.Text
  respuestaUsuario String?            @db.Text
  respuestaIa      String?            @db.Text
  archivoNombre    String?
  contenidoArchivo String?            @db.Text
  archivoKey       String?
  fecha            DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  instancia        InstanciaActividad @relation(fields: [instanciaId], references: [id])
  pregunta         PreguntaActividad  @relation(fields: [preguntaId], references: [id])

  @@unique([instanciaId, preguntaId])
  @@index([instanciaId])
}

model Usuario {
  id                     String                   @id @default(uuid())
  nombre                 String
  email                  String?
  username               String?                  @unique
  password               String?
  roleId                 String?
  puedeIniciarSesion     Boolean                  @default(false)
  googleId               String?                  @unique
  googleEmailVerificado  Boolean                  @default(false)
  cargo                  String?
  empresaId              String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  estado                 String                   @default("activo")
  activo                 Boolean                  @default(true)
  area                   String?
  instancias             InstanciaActividad[]
  empresa                Empresa?                 @relation(fields: [empresaId], references: [id])
  role                   Role?                    @relation(fields: [roleId], references: [id])
  programasFacilita      Programa[]               @relation("ProgramaFacilitador")
  participaciones        ParticipantePrograma[]
  miembroGrupos          MiembroGrupo[]
  asistencias            Asistencia[]             @relation("AsistenciaParticipante")
  asistenciasRegistradas Asistencia[]             @relation("AsistenciaRegistrador")
  gruposCreados          Grupo[]                  @relation("GrupoCreador")
  observacionesRecibidas ObservacionFacilitador[] @relation("ObservacionSobreUsuario")
  observacionesCreadas   ObservacionFacilitador[] @relation("ObservacionAutor")
  magicLinks             MagicLink[]
  plantillasCreadas      PlantillaFormulario[]    @relation("PlantillaCreador")
  respuestasFormulario   RespuestaFormulario[]    @relation("RespuestaRespondiente")
  respuestasEditadas     RespuestaFormulario[]    @relation("RespuestaUltimoEditor")
  presentacionesEntregadas PresentacionFinal[]    @relation("PresentacionEntregadaPor")
  membresiasCliente        UsuarioCliente[]         @relation("UsuarioClienteMiembro")
  invitacionesClienteEnviadas UsuarioCliente[]      @relation("UsuarioClienteInvitadoPor")

  @@unique([empresaId, email], name: "empresa_email_unico")
  @@index([roleId])
}

enum EstadoPrograma {
  borrador
  activo
  finalizado
  cancelado
}

enum EstadoSesion {
  pendiente
  completada
}

enum TipoObservacion {
  baja_participacion
  falta_atencion
  problema_tecnico
  dificultades_estudiante
  otro
}

enum NivelUrgencia {
  normal
  urgente
}

model Programa {
  id            String                   @id @default(uuid())
  nombre        String
  descripcion   String?                  @db.Text
  empresaId     String
  facilitadorId String
  estado        EstadoPrograma           @default(borrador)
  timezone      String                   @default("America/Bogota")
  diasGracia    Int                      @default(3) // RF-03/RN-03: 3 días HÁBILES (solo sáb/dom excluidos)
  totalSesionesEsperadas Int?            // RF-01/RF-04: nº de sesiones esperadas (dashboard "completadas/totales")
  marcarSesionAutomatica Boolean         @default(false) // RF-10: marcar sesión completada al guardar asistencia
  presentacionDesdeSesion Int?           // RF-32: presentación final habilitada a partir de esta sesión
  fechaInicio   DateTime?
  fechaFin      DateTime?
  activo        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  empresa       Empresa                  @relation(fields: [empresaId], references: [id])
  facilitador   Usuario                  @relation("ProgramaFacilitador", fields: [facilitadorId], references: [id])
  sesiones             Sesion[]
  participantes        ParticipantePrograma[]
  grupos               Grupo[]
  miembrosGrupo        MiembroGrupo[]
  observaciones        ObservacionFacilitador[]
  plantillasFormulario PlantillaFormulario[]
  respuestasFormulario RespuestaFormulario[]
  presentacionesFinales PresentacionFinal[]

  @@index([empresaId, estado])
  @@index([facilitadorId])
}

model Sesion {
  id                   String                   @id @default(uuid())
  programaId           String
  numeroSesion         Int
  titulo               String
  descripcion          String?                  @db.Text
  fechaProgramada      DateTime
  materialArchivoKey   String?
  urlGrabacion         String?
  materialDesbloqueoEn DateTime?
  estado               EstadoSesion             @default(pendiente)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  programa             Programa                 @relation(fields: [programaId], references: [id], onDelete: Cascade)
  asistencias          Asistencia[]
  observaciones        ObservacionFacilitador[]

  @@unique([programaId, numeroSesion])
  @@index([programaId])
}

model ParticipantePrograma {
  id         String   @id @default(uuid())
  programaId String
  usuarioId  String
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  programa   Programa @relation(fields: [programaId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([programaId, usuarioId])
  @@index([usuarioId])
}

model Grupo {
  id            String                   @id @default(uuid())
  programaId    String
  nombre        String
  orden         Int
  creadoPorId   String?                  // §7 groups.created_by (admin que creó el grupo)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  programa      Programa                 @relation(fields: [programaId], references: [id], onDelete: Cascade)
  creadoPor            Usuario?                 @relation("GrupoCreador", fields: [creadoPorId], references: [id])
  miembros             MiembroGrupo[]
  observaciones        ObservacionFacilitador[]
  respuestasFormulario RespuestaFormulario[]    @relation("RespuestaGrupo")
  presentacionFinal    PresentacionFinal?

  @@unique([programaId, orden])
  @@index([programaId])
}

model MiembroGrupo {
  id         String   @id @default(uuid())
  grupoId    String
  programaId String   // RN-04: denormalizado desde Grupo.programaId para poder imponer unicidad por programa
  usuarioId  String
  createdAt  DateTime @default(now())
  grupo      Grupo    @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  programa   Programa @relation(fields: [programaId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([programaId, usuarioId]) // RN-04: un estudiante en un solo grupo por programa
  @@index([grupoId])
  @@index([usuarioId])
}

model Asistencia {
  id        String   @id @default(uuid())
  sesionId  String
  usuarioId String
  presente       Boolean  @default(false)
  nota           String?
  registradoPorId String? // §7 attendance.recorded_by (facilitador que registró; RF-19 edición 24 h)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sesion    Sesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation("AsistenciaParticipante", fields: [usuarioId], references: [id])
  registradoPor Usuario? @relation("AsistenciaRegistrador", fields: [registradoPorId], references: [id])

  @@unique([sesionId, usuarioId])
  @@index([usuarioId])
}

model ObservacionFacilitador {
  id           String          @id @default(uuid())
  programaId   String
  sesionId     String?
  usuarioId    String?
  grupoId      String?
  autorId      String
  tipo         TipoObservacion
  urgencia     NivelUrgencia   @default(normal)
  texto        String          @db.Text
  notificadoEn DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  programa     Programa        @relation(fields: [programaId], references: [id], onDelete: Cascade)
  sesion       Sesion?         @relation(fields: [sesionId], references: [id])
  usuario      Usuario?        @relation("ObservacionSobreUsuario", fields: [usuarioId], references: [id])
  grupo        Grupo?          @relation(fields: [grupoId], references: [id])
  autor        Usuario         @relation("ObservacionAutor", fields: [autorId], references: [id])

  @@index([programaId, urgencia])
  @@index([usuarioId])
  @@index([autorId]) // RF-41: facilitador consulta sus propias observaciones
}

model MagicLink {
  id                String    @id @default(uuid())
  tokenHash         String    @unique
  usuarioId         String
  email             String
  propositoRedirect String?
  expiraEn          DateTime
  usadoEn           DateTime?
  ipCreacion        String?
  ipUso             String?
  createdAt         DateTime  @default(now())
  usuario           Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, usadoEn])
  @@index([expiraEn])
}

enum TipoNotificacion {
  invitacion_participante
  material_disponible
  diagnostico_habilitado
  feedback_habilitado
  observacion_normal
  observacion_urgente
  invitacion_usuario_cliente
  magic_link
}

enum EstadoEnvio {
  pendiente
  enviada
  fallida
}

// RNF-12: bitácora de entrega de cada email transaccional (enviada/fallida + reenvío manual).
// Refs a programa/usuario/observacion son "soft" (sin FK) por ser tabla de log append-only.
model NotificacionEmail {
  id                 String           @id @default(uuid())
  tipo               TipoNotificacion
  destinatario       String
  asunto             String
  estado             EstadoEnvio      @default(pendiente)
  proveedorMessageId String?
  error              String?          @db.Text
  intentos           Int              @default(0)
  programaId         String?
  usuarioId          String?
  observacionId      String?
  createdAt          DateTime         @default(now())
  enviadoEn          DateTime?
  updatedAt          DateTime         @updatedAt

  @@index([estado])
  @@index([tipo, createdAt])
  @@index([programaId])
}

// RF-40: listas de destinatarios configurables por el admin (normal vs. urgente).
model ConfiguracionNotificacion {
  id          String   @id @default(uuid())
  clave       String   @unique // admins_observacion_normal | admins_observacion_urgente | ...
  emails      String[]
  descripcion String?
  updatedAt   DateTime @updatedAt
}

// ============================================================
// FASE 2 — Form builder configurable (Plan 1 §4, requisitos §7.2)
// ============================================================

enum TipoFormulario {
  diagnostico_inicial
  diagnostico_final
  feedback
  bitacora
  plantilla_proyecto
}

enum TipoCampo {
  texto_corto
  texto_largo
  numero
  likert
  opcion_multiple
  tabla
  grupo_repetible
}

enum EstadoRespuesta {
  draft
  submitted
}

// RF-22/23/27: programaId=null → template global editable por el admin;
// programaId=X → snapshot inmutable del programa X (RF-46/47/48, RN-10).
model PlantillaFormulario {
  id             String                @id @default(uuid())
  programaId     String?
  tipoFormulario TipoFormulario
  nombre         String
  descripcion    String?               @db.Text
  version        Int                   @default(1) // RF-23: template activo con respuestas no se edita, se versiona
  activa         Boolean               @default(true)
  snapshotDeId   String? // RF-49: global de origen del snapshot (comparar updatedAt del global vs createdAt del snapshot)
  creadoPorId    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  programa       Programa?             @relation(fields: [programaId], references: [id], onDelete: Cascade)
  snapshotDe     PlantillaFormulario?  @relation("PlantillaSnapshot", fields: [snapshotDeId], references: [id], onDelete: SetNull)
  snapshots      PlantillaFormulario[] @relation("PlantillaSnapshot")
  creadoPor      Usuario?              @relation("PlantillaCreador", fields: [creadoPorId], references: [id])
  campos         CampoFormulario[]
  respuestas     RespuestaFormulario[]

  @@index([programaId, tipoFormulario])
  @@index([tipoFormulario, activa])
}

// RF-24/25/26. ⚠ RNF-04/RN-02: configJson contiene los scores ocultos del
// diagnóstico; NUNCA se serializa a roles ≠ danalytics_admin (select sin
// configJson en la capa de servicio). Checkboxes = opcion_multiple con
// {"multiple": true} en configJson (el enum queda en los 7 tipos del RF-24).
model CampoFormulario {
  id            String              @id @default(uuid())
  plantillaId   String
  campoPadreId  String? // hijos de un grupo_repetible (iteraciones de bitácora, RF-30)
  tipoCampo     TipoCampo
  etiqueta      String              @db.Text
  descripcion   String?             @db.Text
  dimension     String? // RF-26: agrupa resultados en reportes (scoring del diagnóstico)
  esObligatorio Boolean             @default(false)
  orden         Int
  configJson    Json                @default("{}")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  plantilla     PlantillaFormulario @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  campoPadre    CampoFormulario?    @relation("CampoHijos", fields: [campoPadreId], references: [id], onDelete: Cascade)
  hijos         CampoFormulario[]   @relation("CampoHijos")

  @@index([plantillaId, orden])
  @@index([campoPadreId])
}

// RF-28/29. Individual (diagnóstico/feedback) → usuarioRespondienteId;
// grupal (bitácora/plantilla proyecto) → grupoRespondienteId. El XOR y la
// unicidad por plantilla se garantizan con CHECK + índices únicos parciales
// creados en scripts/seed-admin.ts (ensureIndices) — db push NO los crea.
model RespuestaFormulario {
  id                     String              @id @default(uuid())
  plantillaId            String
  programaId             String
  usuarioRespondienteId  String?
  grupoRespondienteId    String?
  datosRespuestaJson     Json                @default("{}")
  scoresPorDimensionJson Json? // RF-29: calculado SOLO server-side; el estudiante nunca lo ve
  estado                 EstadoRespuesta     @default(draft)
  ultimoEditorId         String? // RF-16: last_edited_by en recursos de grupo
  ultimaEdicionEn        DateTime?
  enviadoEn              DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  plantilla              PlantillaFormulario @relation(fields: [plantillaId], references: [id])
  programa               Programa            @relation(fields: [programaId], references: [id], onDelete: Cascade)
  usuarioRespondiente    Usuario?            @relation("RespuestaRespondiente", fields: [usuarioRespondienteId], references: [id])
  grupoRespondiente      Grupo?              @relation("RespuestaGrupo", fields: [grupoRespondienteId], references: [id])
  ultimoEditor           Usuario?            @relation("RespuestaUltimoEditor", fields: [ultimoEditorId], references: [id])

  @@index([programaId, estado])
  @@index([plantillaId])
  @@index([usuarioRespondienteId])
  @@index([grupoRespondienteId])
}

// ============================================================
// FASE 3 — Reto con IA: presentación final (Plan 1 §5, requisitos §7.3)
// ============================================================

// RF-32 (§7.3 final_presentations). Una presentación por grupo (@@unique([grupoId])).
// El grupo entrega link (urlPresentacion) O archivo PDF/PPT en S3 (archivoKey): al
// menos uno debe estar presente. Ese CHECK ("url o archivo") lo aplica
// scripts/seed-admin.ts (ensureIndices) — db push NO crea CHECK constraints.
// programaId está denormalizado para consultas por programa (RF-37/38).
model PresentacionFinal {
  id              String    @id @default(uuid())
  grupoId         String
  programaId      String
  urlPresentacion String?
  archivoKey      String? // S3
  entregadoPorId  String? // §7.3 submitted_by
  entregadoEn     DateTime? // §7.3 submitted_at
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  grupo           Grupo     @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  programa        Programa  @relation(fields: [programaId], references: [id], onDelete: Cascade)
  entregadoPor    Usuario?  @relation("PresentacionEntregadaPor", fields: [entregadoPorId], references: [id], onDelete: SetNull)

  @@unique([grupoId])
  @@index([programaId])
}

// ============================================================
// FASE 4 — Portal del cliente y auditoría (Plan 1 §6, requisitos RF-42..RF-45)
// ============================================================

// RF-44/45: tabla puente Usuario (role=cliente_admin/usuario_cliente) ↔ Empresa.
// La revocación de acceso NO borra la fila: se marca activo=false para conservar
// la historia (quién invitó, cuándo). La unicidad de un solo cliente_admin ACTIVO
// por empresa se garantiza con un índice único PARCIAL sobre Usuario, creado en
// scripts/seed-admin.ts (usuario_cliente_admin_unico_por_empresa) — db push NO
// crea índices parciales. Ver Plan 1 §6/§12 y Plan 2 §4.4 (CLIENTE_ADMIN_UNICO).
model UsuarioCliente {
  id            String   @id @default(uuid())
  empresaId     String
  usuarioId     String
  invitadoPorId String? // quién invitó (RF-44); soft-nullable si fue creado por danalytics_admin
  invitadoEn    DateTime @default(now())
  activo        Boolean  @default(true) // revocación = false (no borrado, conserva historia — RF-44)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario       Usuario  @relation("UsuarioClienteMiembro", fields: [usuarioId], references: [id])
  invitadoPor   Usuario? @relation("UsuarioClienteInvitadoPor", fields: [invitadoPorId], references: [id])

  @@unique([empresaId, usuarioId])
  @@index([usuarioId])
  @@index([empresaId, activo])
}

// RNF-13: bitácora de auditoría append-only. Refs "soft" (SIN foreign key) a
// usuarioId/recursoId — mismo patrón que NotificacionEmail — para que la baja de
// un usuario nunca borre ni bloquee el log de auditoría.
// `accion` y `tipoRecurso` son String (NO enum): la lista de valores crece con el
// tiempo y no queremos una migración por cada valor nuevo.
//   accion (esperado):      login | logout | crear_usuario | editar_usuario |
//     eliminar_usuario | reset_password | invitar_usuario_cliente |
//     revocar_usuario_cliente | reenviar_invitacion | ver_programa |
//     ver_registro_acceso
//   tipoRecurso (esperado): usuario | usuario_cliente | programa | sesion |
//     respuesta_formulario | presentacion_final | registro_acceso
model RegistroAcceso {
  id          String   @id @default(uuid())
  usuarioId   String // soft ref (sin FK) — quién ejecutó la acción
  role        String // slug del rol en el momento de la acción (snapshot denormalizado)
  accion      String
  tipoRecurso String
  recursoId   String? // soft ref (sin FK) — id del recurso afectado
  ipAddress   String?
  userAgent   String?  @db.Text
  creadoEn    DateTime @default(now())

  @@index([usuarioId, creadoEn])
}

model Translation {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  field      String
  locale     String
  value      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId, locale])
}

model CanvasBloque {
  id          String             @id @default(uuid())
  instanciaId String
  pasoId      String
  resumen     String             @db.Text
  locale      String             @default("es")
  generadoEn  DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  instancia   InstanciaActividad @relation(fields: [instanciaId], references: [id])
  paso        PasoActividad      @relation(fields: [pasoId], references: [id])

  @@unique([instanciaId, pasoId])
  @@index([instanciaId])
}
