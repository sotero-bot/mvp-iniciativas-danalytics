{
    "version": 2,
    "buildCommand": "npm run vercel-build",
    "outputDirectory": "dist/web",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/internal/jobs/material-disponible",
            "schedule": "0 * * * *"
        }
    ]
}