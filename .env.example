# PostgreSQL (Vercel Postgres o compatible)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_PORT=5432

# JWT
SUPABASE_JWT_SECRET=SECRET_KEY_MVP

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Email — selector de transporte: resend | smtp | gmail_api
# Sin credenciales para el transporte elegido, EmailService loguea los envíos a consola.
EMAIL_TRANSPORT=smtp
EMAIL_FROM="Danalytics <no-reply@danalytics.co>"

# Opción 1 — Gmail SMTP + App Password (MVP, EMAIL_TRANSPORT=smtp).
# Requiere 2FA activo en la cuenta de Google y una App Password generada en
# https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=

# Opción 2 — Gmail API + Service Account (FUTURO, EMAIL_TRANSPORT=gmail_api, aún no se usa).
# Ver apps/api/src/modules/email/transports/gmail-api.transport.ts para la guía de migración.
# GMAIL_API_SERVICE_ACCOUNT_JSON=
# GMAIL_API_IMPERSONATE_USER=

# Resend (alternativa, EMAIL_TRANSPORT=resend).
RESEND_API_KEY=

# Base URL usada para construir los enlaces MagicLink en emails.
APP_BASE_URL=http://localhost:5173

# Destinatarios de observaciones del facilitador (RF-40). Coma-separados.
# Solo se usan como valor inicial en el primer deploy; luego se editan por UI/BD.
NOTIF_ADMIN_EMAILS=
NOTIF_ADMIN_EMAILS_URGENTE=

# Admin — credenciales del usuario administrador (scripts/seed-admin.ts).
# ADMIN_PASSWORD es OBLIGATORIA: el seed falla si no está definida.
# En Vercel, configúralas en Project Settings → Environment Variables.
ADMIN_USERNAME=admin
ADMIN_NOMBRE=Admin Principal
ADMIN_PASSWORD=

# Google OAuth2 (login con Google, RF-13). Credenciales en Google Cloud Console
# (OAuth client ID tipo Web application). Vacío = login con Google deshabilitado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Secreto compartido para el batch "material disponible" (RF-40/§8), disparado por
# Vercel Cron. Vercel firma sus llamadas con `Authorization: Bearer $CRON_SECRET`
# automáticamente cuando esta env var existe en el proyecto. Vacío = el endpoint
# interno rechaza toda llamada (403).
CRON_SECRET=
