# PostgreSQL (Vercel Postgres o compatible)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_PORT=5432

# JWT
SUPABASE_JWT_SECRET=SECRET_KEY_MVP

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Email (Resend). Sin RESEND_API_KEY, EmailService loguea los envíos a consola en dev.
RESEND_API_KEY=
EMAIL_FROM="Danalytics <no-reply@danalytics.co>"

# Base URL usada para construir los enlaces MagicLink en emails.
APP_BASE_URL=http://localhost:5173

# Destinatarios de observaciones del facilitador (RF-40). Coma-separados.
# Solo se usan como valor inicial en el primer deploy; luego se editan por UI/BD.
NOTIF_ADMIN_EMAILS=
NOTIF_ADMIN_EMAILS_URGENTE=
